# HTTP port. Locally defaults to 3001; PaaS hosts (Render/Fly) inject this.
PORT=3001

# Comma-separated CORS allowlist for both the REST API and the /consult
# socket.io gateway. Unset -> falls back to http://localhost:5173 (Vite dev).
# In production set this to the deployed frontend origin, e.g.:
# CORS_ORIGINS=https://pettography.vercel.app
CORS_ORIGINS=

# Global API rate limit from @nestjs/throttler. Defaults match sibling Nest APIs:
# 120 requests per 60 seconds per client.
API_THROTTLE_TTL_MS=60000
API_THROTTLE_LIMIT=120

# HS256 secret used to sign session JWTs (auth/jwt.ts). Sessions are signed JWTs;
# scrypt is still used for PASSWORD hashing. Unset -> falls back to an insecure
# dev default. In production set a long, random, unique secret, e.g.:
# PETTOGRAPHY_JWT_SECRET=$(openssl rand -base64 48)
# Rotating this invalidates all outstanding JWTs (users simply re-login).
PETTOGRAPHY_JWT_SECRET=
