# Frontend API base URL. Same-origin /api works with local proxy/reverse proxy setups.
VITE_API_URL=/api

# Optional Kakao JavaScript map key. This is a public browser key, not a secret.
VITE_KAKAO_MAP_KEY=

# ==========================================================================
# DeskCloud widgets — every widget is env-gated: it renders ONLY when its
# VITE_*DESK_URL is set. Leave a URL blank to disable that Desk (default).
# The publishable key (VITE_*DESK_PK, pk_…) is a public browser key, not a
# secret; it defaults to pk_demo when unset. Set the live URLs in your
# deployment env (Vercel project settings) — keep them out of committed source.
# The example value after each entry is the live production endpoint.
# ==========================================================================

# SurveyDesk — feedback survey widget (floating "피드백" button on every page).
# Live: https://surveydesk-api.vercel.app
VITE_SURVEYDESK_URL=
# SurveyDesk publishable key (pk_…); defaults to pk_demo.
VITE_SURVEYDESK_PK=

# ChangelogDesk — floating "새 소식" changelog launcher.
# Live: https://changelogdesk-api.vercel.app
VITE_CHANGELOGDESK_URL=
# ChangelogDesk publishable key (pk_…); defaults to pk_demo.
VITE_CHANGELOGDESK_PK=

# NotifyDesk — floating notification bell (bottom-right, above the launchers).
# Live: https://notifydesk-api.vercel.app
VITE_NOTIFYDESK_URL=
# NotifyDesk publishable key (pk_…); defaults to pk_demo.
VITE_NOTIFYDESK_PK=

# SearchDesk — ⌘⇧K search palette (the app's own ⌘K command palette stays primary).
# Live: https://searchdesk-api.vercel.app
VITE_SEARCHDESK_URL=
# SearchDesk publishable key (pk_…); defaults to pk_demo.
VITE_SEARCHDESK_PK=

# CommunityDesk — floating community feed launcher.
# Live: https://communitydesk-api.vercel.app
VITE_COMMUNITYDESK_URL=
# CommunityDesk publishable key (pk_…); defaults to pk_demo.
VITE_COMMUNITYDESK_PK=

# ReviewDesk — floating review form launcher.
# Live: https://reviewdesk-api.vercel.app
VITE_REVIEWDESK_URL=
# ReviewDesk publishable key (pk_…); defaults to pk_demo.
VITE_REVIEWDESK_PK=

# MediaDesk — floating media gallery launcher.
# Live: https://16.176.210.195.nip.io/media
VITE_MEDIADESK_URL=
# MediaDesk publishable key (pk_…); defaults to pk_demo.
VITE_MEDIADESK_PK=

# --------------------------------------------------------------------------
# Available DeskCloud Desks NOT auto-mounted in this app (no homegrown
# feature to replace, and they would be net-new heavy additions). They are
# documented here so a deployment can opt in later; wiring is intentionally
# deferred to keep this change safe and reversible.
#   ChatDesk      DM/group chat       Live: https://16.176.210.195.nip.io/chat
#                 (needs the socket.io-client dependency; the app has none today)
#   RealtimeDesk  presence/live       Live: https://16.176.210.195.nip.io/realtime
#                 (no natural home; pettography has no presence surface)
#   ModerationDesk report/moderation  Live: https://16.176.210.195.nip.io/moderation
#                 (the app already has a first-party /admin moderation queue — a
#                  core feature — so this is intentionally NOT replaced)
# --------------------------------------------------------------------------
