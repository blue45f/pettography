# Frontend API base URL. Same-origin /api works with local proxy/reverse proxy setups.
VITE_API_URL=/api

# Optional Kakao JavaScript map key. This is a public browser key, not a secret.
VITE_KAKAO_MAP_KEY=

# ==========================================================================
# Unified member login — Firebase Authentication (project: deskcloud-fleet-auth).
# Web apiKey/appId are PUBLIC identifiers (security is enforced by Auth rules +
# authorizedDomains), but the repo secret-scan hook blocks the AIza… pattern, so
# these are injected via env only — never committed literally. Supply real values
# in .env.local (gitignored) + the Vercel project env. authDomain/projectId
# default to deskcloud-fleet-auth.* when unset. With apiKey/appId unset the app
# still builds; login is gated at runtime by isFirebaseAuthConfigured.
# ==========================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ==========================================================================
# DeskCloud — NATIVE integration via the published SDK (@heejun/deskcloud).
# NOT widget embeds: each Desk is called through its typed browser (pk_) client
# and rendered with this app's OWN components + design tokens (DeskHub).
#
# Every Desk is env-gated: it is active ONLY when its VITE_*DESK_URL is set.
# Leave a URL blank to disable that Desk (default) — the app falls back to its
# first-party feature, so the integration is fully reversible. Active Desks
# appear as tabs in the native DeskHub launcher (bottom-right).
#
# The publishable key (VITE_*DESK_PK, pk_…) is a PUBLIC browser key, not a
# secret; it defaults to pk_demo when unset. Never put a secret sk_ key in any
# VITE_* var. Set the live URLs in your deployment env (Vercel project
# settings) — keep them out of committed source. The example value after each
# entry is the live production endpoint.
# ==========================================================================

# SurveyDesk — native feedback form (DeskHub "피드백" tab; getActive/submit).
# Live: https://surveydesk-api.vercel.app
VITE_SURVEYDESK_URL=
# SurveyDesk publishable key (pk_…); defaults to pk_demo.
VITE_SURVEYDESK_PK=

# ChangelogDesk — native "새 소식" entries (DeskHub tab; getWall/markSeen).
# Live: https://changelogdesk-api.vercel.app
VITE_CHANGELOGDESK_URL=
# ChangelogDesk publishable key (pk_…); defaults to pk_demo.
VITE_CHANGELOGDESK_PK=

# NotifyDesk — native notification inbox (DeskHub tab + launcher badge;
# getInbox/getUnreadCount/markRead). Live: https://notifydesk-api.vercel.app
VITE_NOTIFYDESK_URL=
# NotifyDesk publishable key (pk_…); defaults to pk_demo.
VITE_NOTIFYDESK_PK=

# SearchDesk — native content search (DeskHub tab; search). The app's own ⌘K
# command palette stays the primary navigation search.
# Live: https://searchdesk-api.vercel.app
VITE_SEARCHDESK_URL=
# SearchDesk publishable key (pk_…); defaults to pk_demo.
VITE_SEARCHDESK_PK=

# CommunityDesk — native external board feed (DeskHub tab; listPosts). The
# app's own /communities and /forum stay the first-party community surfaces.
# Live: https://communitydesk-api.vercel.app
VITE_COMMUNITYDESK_URL=
# CommunityDesk publishable key (pk_…); defaults to pk_demo.
VITE_COMMUNITYDESK_PK=

# ReviewDesk — native testimonials wall + submit (DeskHub tab;
# getAggregate/getWall/submit). Live: https://reviewdesk-api.vercel.app
VITE_REVIEWDESK_URL=
# ReviewDesk publishable key (pk_…); defaults to pk_demo.
VITE_REVIEWDESK_PK=

# MediaDesk — native external media gallery (DeskHub tab; listAssets +
# on-the-fly thumbnails). The in-app photo pipeline stays the core feature.
# Live: https://16.176.210.195.nip.io/media
VITE_MEDIADESK_URL=
# MediaDesk publishable key (pk_…); defaults to pk_demo.
VITE_MEDIADESK_PK=

# --------------------------------------------------------------------------
# DeskCloud Desks intentionally NOT wired here (skipped, per the native plan):
#   ChatDesk      DM/group chat       Live: https://16.176.210.195.nip.io/chat
#                 (socket-based; the app has no DM surface — net-new, deferred)
#   RealtimeDesk  presence/live       Live: https://16.176.210.195.nip.io/realtime
#                 (socket-based; no presence surface in this app — deferred)
#   ModerationDesk report/moderation  Live: https://16.176.210.195.nip.io/moderation
#                 (the app already has a first-party /admin moderation queue — a
#                  CORE feature — so this is intentionally NOT replaced)
# These are reachable via the same SDK (createChatClient / createRealtimeClient
# / createModerationClient) if a future deployment opts in.
# --------------------------------------------------------------------------
