# Frontend API base URL. Same-origin /api works with local proxy/reverse proxy setups.
VITE_API_URL=/api

# Optional Kakao JavaScript map key. This is a public browser key, not a secret.
VITE_KAKAO_MAP_KEY=

# Optional SurveyDesk endpoint. When set, the feedback widget appears on every page; unset = no widget.
VITE_SURVEYDESK_URL=

# Optional ChangelogDesk endpoint. When set, a floating "새 소식" changelog launcher appears; unset = off.
VITE_CHANGELOGDESK_URL=
# Optional ChangelogDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_CHANGELOGDESK_PK=

# Optional NotifyDesk endpoint. When set, a notification bell appears top-right; unset = off.
VITE_NOTIFYDESK_URL=
# Optional NotifyDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_NOTIFYDESK_PK=

# Optional SearchDesk endpoint. When set, a ⌘⇧K search palette is enabled; unset = off.
VITE_SEARCHDESK_URL=
# Optional SearchDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_SEARCHDESK_PK=

# Optional CommunityDesk endpoint. When set, a floating community feed launcher appears; unset = off.
VITE_COMMUNITYDESK_URL=
# Optional CommunityDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_COMMUNITYDESK_PK=

# Optional ReviewDesk endpoint. When set, a floating review form launcher appears; unset = off.
VITE_REVIEWDESK_URL=
# Optional ReviewDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_REVIEWDESK_PK=

# Optional MediaDesk endpoint. When set, a floating media gallery launcher appears; unset = off.
VITE_MEDIADESK_URL=
# Optional MediaDesk publishable key (pk_…). Public browser key, not a secret; defaults to pk_demo.
VITE_MEDIADESK_PK=
