{
  "name": "pettography",
  "description": "희귀 애완동물 종 선택부터 위치 기반 병원·샵·관리 정보까지 연결하는 포탈 앱",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "pnpm --filter pettography-backend run dev",
    "build:shared": "pnpm --filter @pettography/shared run build",
    "build": "pnpm run build:shared && tsc -b && vite build",
    "build:backend": "pnpm run build:shared && pnpm --filter pettography-backend run build",
    "lint": "eslint .",
    "lint:security": "eslint . --max-warnings=0 && pnpm audit:security",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist coverage storybook-static",
    "preview": "vite preview",
    "test": "vitest",
    "test:backend": "pnpm --filter pettography-backend run test",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:i18n": "vitest run src/i18n/locales.test.ts",
    "typecheck": "tsc -b --noEmit",
    "audit:security": "pnpm audit --audit-level high",
    "ci": "pnpm run build:shared && pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run test:run && pnpm run test:node && pnpm run audit:a11y && pnpm run build",
    "verify": "pnpm run validate:architecture && pnpm run validate:env && pnpm run ci",
    "verify:backend": "pnpm --filter pettography-backend run verify",
    "verify:all": "pnpm run verify && pnpm run verify:backend",
    "verify:push": "pnpm run verify && pnpm run lint:security",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "validate:architecture": "node scripts/validate-architecture.mjs",
    "audit:a11y": "node scripts/audit-frontend-a11y.mjs",
    "test:a11y": "node scripts/audit-frontend-a11y.test.mjs",
    "test:env": "node --test scripts/validate-env.test.mjs",
    "test:node": "node --test scripts/*.test.mjs",
    "validate:env": "node scripts/validate-env.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@pettography/shared": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "ky": "^2.0.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.17.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/react-vite": "^10.4.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "storybook": "^10.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
